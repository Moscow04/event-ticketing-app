NODE_ENV=production
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=event_ticketing
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# JWT
JWT_SECRET=generate-64-char-random-hex-string-here
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin seed
ADMIN_EMAIL=admin@eventtix.com
ADMIN_PASSWORD=Admin@123456
